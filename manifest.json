{
  "manifest_version": 3,
  "name": "NotoSansへ置換するやつ(改修型)",
  "version": "2.0.50",
  "description": "読みづらいフォントをNoto Sansに自動置換。パフォーマンス改善版。",
  "minimum_chrome_version": "102",
  "icons": {
    "16": "icons/icon-16x16.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "https://*.stripe.com/*",
        "https://*.stripe.network/*",
        "https://*.paypal.com/*",
        "https://www.google.com/recaptcha/*",
        "https://www.recaptcha.net/recaptcha/*",
        "https://*.hcaptcha.com/*",
        "https://challenges.cloudflare.com/*",
        "https://accounts.google.com/*",
        "https://login.microsoftonline.com/*",
        "https://*.auth0.com/*"
      ],
      "js": [
        "src/content/preload-fonts.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "https://*.stripe.com/*",
        "https://*.stripe.network/*",
        "https://*.paypal.com/*",
        "https://www.google.com/recaptcha/*",
        "https://www.recaptcha.net/recaptcha/*",
        "https://*.hcaptcha.com/*",
        "https://challenges.cloudflare.com/*",
        "https://accounts.google.com/*",
        "https://login.microsoftonline.com/*",
        "https://*.auth0.com/*"
      ],
      "js": [
        "src/content/inject.js"
      ],
      "world": "MAIN",
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/fonts/*.woff2",
        "src/css/*.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
