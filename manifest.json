{
  "manifest_version": 3,
  "name": "NotoSansへ置換するやつ(改修型)",
  "version": "2.0.49",
  "description": "読みづらいフォントをNoto Sansに自動置換。パフォーマンス改善版。",
  "icons": {
    "16": "icons/icon-16x16.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/preload-fonts.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/fonts/*.woff2",
        "src/css/*.css",
        "src/content/inject.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}